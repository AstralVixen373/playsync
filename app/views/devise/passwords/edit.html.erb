<% content_for :title, t("devise.passwords.edit.title") %>
<h2><%= t("devise.passwords.edit.title") %></h2>

<%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
  <div id="error-notification">
  <%= f.error_notification %>
</div>

  <%= f.input :reset_password_token, as: :hidden %>
  <%= f.full_error :reset_password_token %>

  <div class="form-inputs">
    <%= f.input :password,
                label: t("devise.passwords.edit.new_password"),
                required: true,
                autofocus: true,
                hint: (t("devise.registrations.new.min_password", count: @minimum_password_length) if @minimum_password_length),
                input_html: { autocomplete: "new-password" } %>
    <%= f.input :password_confirmation,
                label: t("devise.passwords.edit.confirm_password"),
                required: true,
                input_html: { autocomplete: "new-password" } %>
  </div>

  <div class="form-actions">
    <%= f.button :submit, t("devise.passwords.edit.submit") %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
