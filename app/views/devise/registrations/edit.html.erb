<% content_for :title, t("devise.registrations.edit.title") %>
<% content_for :page_title do %>
  <h1><%= t("devise.registrations.edit.title") %></h1>
  <p><%= t("devise.registrations.edit.subtitle") %></p>
<% end %>

<% avatar_initial = (resource.username.presence || resource.email).first.upcase %>

<%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name),
      html: { method: :put, class: "ps-profile" }) do |f| %>

  <div id="error-notification">
    <%= f.error_notification %>
  </div>

  <div class="ps-profile__grid">

    <%# ── Avatar ────────────────────────────────────────────────────────── %>
    <section class="ps-profile__group" data-controller="avatar" data-avatar-initial-value="<%= avatar_initial %>">
      <h2 class="ps-profile__section-label"><%= t("devise.registrations.edit.avatar_section") %></h2>

      <div class="ps-profile__card ps-profile__avatar-card">
        <div class="ps-profile__avatar">
          <span class="ps-profile__avatar-img" data-avatar-target="preview">
            <% if resource.avatar.attached? %>
              <%= image_tag resource.avatar, alt: t("devise.registrations.edit.avatar_section") %>
            <% else %>
              <%= avatar_initial %>
            <% end %>
          </span>
          <button type="button" class="ps-profile__avatar-badge"
                  data-action="avatar#choose"
                  aria-label="<%= t("devise.registrations.edit.choose_avatar") %>">
            <i class="fa-solid fa-camera"></i>
          </button>
        </div>

        <div class="ps-profile__avatar-info">
          <h3><%= resource.username.presence || resource.email %></h3>
          <p><%= t("devise.registrations.edit.avatar_hint") %></p>
          <div class="ps-profile__avatar-actions">
            <button type="button" class="btn" data-action="avatar#choose">
              <%= t("devise.registrations.edit.choose_avatar") %>
            </button>
            <button type="button" class="ps-profile__btn-outline" data-action="avatar#remove">
              <%= t("devise.registrations.edit.remove_avatar") %>
            </button>
          </div>
        </div>

        <%= f.file_field :avatar, accept: "image/*", class: "ps-profile__file",
              data: { avatar_target: "input", action: "avatar#preview" } %>
        <input type="hidden" name="user[remove_avatar]" value="" data-avatar-target="removeFlag">
      </div>
    </section>

    <%# ── Username ──────────────────────────────────────────────────────── %>
    <section class="ps-profile__group">
      <h2 class="ps-profile__section-label"><%= t("devise.registrations.edit.username_section") %></h2>

      <div class="ps-profile__card ps-profile__field-card">
        <div class="ps-profile__field">
          <label for="user_username"><%= t("devise.registrations.edit.username_label") %></label>
          <%= f.text_field :username, id: "user_username", class: "ps-profile__input", autofocus: true %>
        </div>
        <% if resource.username.present? %>
          <i class="fa-solid fa-check ps-profile__check" aria-hidden="true"></i>
        <% end %>
      </div>
    </section>

    <%# ── Platform IDs (Gamertag, PSN ID, …) ────────────────────────────── %>
    <section class="ps-profile__group">
      <h2 class="ps-profile__section-label"><%= t("devise.registrations.edit.platform_ids") %></h2>

      <div class="ps-profile__card">
        <p class="ps-profile__card-hint"><%= t("devise.registrations.edit.platform_ids_hint") %></p>

        <div class="ps-profile__platforms">
          <% Post::PLATFORMS.each do |platform| %>
            <% field_id = "user_platform_handle_#{PlatformsHelper::PLATFORM_HANDLE_SLUGS[platform]}" %>
            <div class="ps-profile__platform">
              <span class="ps-profile__platform-icon"><%= platform_icon(platform, size: 22) %></span>
              <label class="ps-profile__platform-name" for="<%= field_id %>"><%= platform %></label>
              <input type="text"
                     id="<%= field_id %>"
                     name="user[platform_handles][<%= platform %>]"
                     value="<%= resource.platform_handle(platform) %>"
                     placeholder="<%= platform_handle_label(platform) %>"
                     autocomplete="off"
                     class="ps-profile__input ps-profile__platform-input">
            </div>
          <% end %>
        </div>
      </div>
    </section>

    <%# ── Filter preferences ────────────────────────────────────────────── %>
    <section class="ps-profile__group" data-controller="preferences">
      <div class="ps-profile__group-head">
        <h2 class="ps-profile__section-label"><%= t("devise.registrations.edit.filter_preferences") %></h2>
        <%= button_tag t("devise.registrations.edit.reset_filters"), type: "button",
              data: { action: "preferences#reset" }, class: "ps-profile__reset" %>
      </div>

      <div class="ps-profile__card">
        <p class="ps-profile__card-hint"><%= t("devise.registrations.edit.filter_hint") %></p>

        <div class="ps-profile__field">
          <label><%= t("devise.registrations.edit.preferred_games") %></label>
          <input type="text" id="profile-game-search" placeholder="<%= t("devise.registrations.edit.search_game") %>"
                 autocomplete="off" class="ps-profile__input">
          <div id="profile-game-results"></div>
          <div id="profile-game-chips" data-field="user[preferred_game_ids][]"
               style="display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.5rem;">
            <%# Always submit at least an empty value so games can be cleared. %>
            <input type="hidden" name="user[preferred_game_ids][]" value="">
            <% resource.preferred_games.each do |game| %>
              <span class="game-chip" style="display: inline-flex; align-items: center; gap: 0.3rem; background: #eef; border-radius: 12px; padding: 0.15rem 0.6rem; font-size: 0.85rem;">
                <input type="hidden" name="user[preferred_game_ids][]" value="<%= game.id %>">
                <%= game.name %>
                <button type="button" class="game-chip-remove" style="border: none; background: none; cursor: pointer; font-weight: bold;">×</button>
              </span>
            <% end %>
          </div>
        </div>

        <div class="ps-profile__field">
          <label><%= t("devise.registrations.edit.preferred_platforms") %></label>
          <%= render "shared/multiselect", name: "user[preferred_platforms][]", options: Post::PLATFORMS, selected: resource.preferred_platforms, placeholder: t("devise.registrations.edit.no_preference"), include_hidden: true %>
        </div>

        <div class="ps-profile__field">
          <label><%= t("devise.registrations.edit.preferred_types") %></label>
          <%= render "shared/multiselect", name: "user[preferred_post_types][]", options: Post::TYPES, selected: resource.preferred_post_types, placeholder: t("devise.registrations.edit.no_preference"), include_hidden: true %>
        </div>

        <div class="ps-profile__field">
          <label><%= t("devise.registrations.edit.preferred_language") %></label>
          <div class="ps-profile__input-wrap">
            <%= render "shared/multiselect",
                  name: "user[preferred_language]",
                  options: Post::LANGUAGES,
                  selected: resource.preferred_language,
                  placeholder: t("devise.registrations.edit.no_preference"),
                  single: true,
                  labels: Post::LANGUAGES.index_with { |l| t("post_languages.#{l}") } %>
            <% if resource.preferred_language.present? %>
              <i class="fa-solid fa-check ps-profile__check ps-profile__check--inline" aria-hidden="true"></i>
            <% end %>
          </div>
        </div>
      </div>
    </section>

  </div>

  <div class="ps-profile__actions">
    <%= f.button :submit, t("devise.registrations.edit.submit"), class: "btn ps-profile__submit" %>
  </div>
<% end %>
