<h2>Edit <%= resource_name.to_s.humanize %></h2>

<%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <div id="error-notification">
  <%= f.error_notification %>
</div>

  <div class="form-inputs">
    <% if resource.avatar.attachment&.persisted? %>
      <%= image_tag resource.avatar, class: "rounded-circle mb-2", style: "width: 120px; height: 120px;", alt: "Current avatar" %>
    <% end %>
    <%= f.input :avatar, as: :file, label: "Avatar", input_html: { accept: "image/*" } %>

    <%= f.input :email, required: true, autofocus: true %>
    <%= f.input :username, required: false, autofocus: true %>

    <fieldset data-controller="preferences" style="border: 1px solid #e0e0e0; border-radius: 6px; padding: 1rem; margin: 1rem 0;">
      <legend style="font-weight: bold; padding: 0 0.5rem;">🎮 Filter preferences</legend>
      <div style="display: flex; justify-content: space-between; align-items: baseline; gap: 1rem;">
        <p style="color: #888; font-size: 0.85rem; margin-top: 0;">
          These pre-fill the search and the new-post form. Leave empty for no preference.
        </p>
        <%= button_tag "Reset filters", type: "button",
              data: { action: "preferences#reset" },
              style: "border: none; background: none; color: #007bff; cursor: pointer; padding: 0; white-space: nowrap;" %>
      </div>

      <div style="margin-bottom: 1rem;">
        <label style="display: block; margin-bottom: 0.5rem; font-weight: bold;">Preferred games</label>
        <input type="text" id="profile-game-search" placeholder="Search a game..."
               autocomplete="off"
               style="width:100%; padding:0.5rem; border: 1px solid #e0e0e0; border-radius: 4px;">
        <div id="profile-game-results"></div>
        <div id="profile-game-chips" data-field="user[preferred_game_ids][]"
             style="display: flex; flex-wrap: wrap; gap: 0.4rem; margin-top: 0.5rem;">
          <%# Always submit at least an empty value so games can be cleared. %>
          <input type="hidden" name="user[preferred_game_ids][]" value="">
          <% resource.preferred_games.each do |game| %>
            <span class="game-chip" style="display: inline-flex; align-items: center; gap: 0.3rem; background: #eef; border-radius: 12px; padding: 0.15rem 0.6rem; font-size: 0.85rem;">
              <input type="hidden" name="user[preferred_game_ids][]" value="<%= game.id %>">
              <%= game.name %>
              <button type="button" class="game-chip-remove" style="border: none; background: none; cursor: pointer; font-weight: bold;">×</button>
            </span>
          <% end %>
        </div>
      </div>

      <div style="margin-bottom: 1rem;">
        <label style="display: block; margin-bottom: 0.5rem; font-weight: bold;">Preferred platforms</label>
        <%= render "shared/multiselect", name: "user[preferred_platforms][]", options: Post::PLATFORMS, selected: resource.preferred_platforms, placeholder: "No preference", include_hidden: true %>
      </div>

      <div style="margin-bottom: 1rem;">
        <label style="display: block; margin-bottom: 0.5rem; font-weight: bold;">Preferred types</label>
        <%= render "shared/multiselect", name: "user[preferred_post_types][]", options: Post::TYPES, selected: resource.preferred_post_types, placeholder: "No preference", include_hidden: true %>
      </div>

      <%= f.input :preferred_language,
                  collection: Post::LANGUAGES,
                  include_blank: "No preference",
                  label: "Preferred language" %>
    </fieldset>

    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
      <p>Currently waiting confirmation for: <%= resource.unconfirmed_email %></p>
    <% end %>

    <%= f.input :password,
                hint: "leave it blank if you don't want to change it",
                required: false,
                input_html: { autocomplete: "new-password" } %>
    <%= f.input :password_confirmation,
                required: false,
                input_html: { autocomplete: "new-password" } %>
  </div>

  <div class="form-actions">
    <%= f.button :submit, "Update" %>
  </div>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <div class="auth-divider" aria-hidden="true"></div>

  <div class="auth-provider-actions">
    <% resource_class.omniauth_providers.each do |provider| %>
      <% identity = current_user.identities %>

      <% if current_user.identities.exists?(provider: "steam") && provider.to_s == "steam" %>
        <p>Compte Steam de <%= current_user.identities[0][:nickname] %></p>
        <a class="btn" href="https://steamcommunity.com/profiles/<%= current_user.identities[0][:uid] %>">Voir le compte Steam</a>
      <% elsif provider.to_s == "steam" %>
        <%= button_to user_steam_omniauth_authorize_path,
              method: :post,
              form: { data: { turbo: "false" } },
              class: "auth-provider-form" do %>
                <%= image_tag "https://community.akamai.steamstatic.com/public/images/signinthroughsteam/sits_01.png",
                alt: "steam connection button", aria: { hidden: true }, class: "steam_logo" %>
              <% end %>
      <% end %>

      <% if current_user.identities.exists?(provider: "twitch") && provider.to_s == "twitch" %>
        <p>Compte Twitch de <%= current_user.identities[1][:nickname] %></p>
        <a class="btn" href="https://www.twitch.tv/<%= current_user.identities[1][:nickname] %>">Voir le compte Twitch</a>
      <% elsif provider.to_s == "twitch" %>
        <%= button_to user_twitch_omniauth_authorize_path,
              method: :post,
              form: { data: { turbo: "false" } },
              class: "auth-provider-form" do %>
                <%= image_tag "twitch_emblem.png", alt: "Twitch connection button", aria: { hidden: true }, class: "twitch_logo" %>
              <% end %>
      <% end %>
    <% end %>
  </div>
<% end %>


<h3>Cancel my account</h3>

<div>Unhappy? <%= button_to "Cancel my account", registration_path(resource_name), data: { confirm: "Are you sure?", turbo_confirm: "Are you sure?" }, method: :delete %></div>

<%= link_to "Back", :back %>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const errorFlash = document.getElementById("error-notification");

    // On vérifie si la notification contient bien du texte (si une erreur existe)
    if (errorFlash && errorFlash.innerText.trim() !== "") {
      setTimeout(() => {
        // Effet de transition pour une disparition fluide
        errorFlash.style.transition = "opacity 0.5s ease";
        errorFlash.style.opacity = "0";

        // On retire complètement l'élément du DOM après l'effet
        setTimeout(() => {
          errorFlash.remove();
        }, 500);
      }, 5000); // 5000 ms = 5 secondes avant de commencer à disparaître
    }
  });
</script>
