<div style="text-align: center; padding: 3rem 0;">
  <h1 style="font-size: 2.5rem; margin-bottom: 1rem;">🎮 <%= t("home.title") %></h1>
  <p style="font-size: 1.1rem; color: #666; margin-bottom: 2rem;"><%= t("home.subtitle") %></p>

  <% if user_signed_in? %>
    <p style="margin-bottom: 2rem;">
      <%= link_to t("home.browse_posts"), posts_path, class: "btn", style: "font-size: 1.1rem; padding: 0.8rem 2rem;" %>
      <%= link_to t("home.create_post"), new_post_path, class: "btn", style: "font-size: 1.1rem; padding: 0.8rem 2rem; margin-left: 1rem;" %>
    </p>
  <% end %>
</div>
