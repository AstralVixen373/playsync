<%# Round user avatar with a soft ring. Uses the existing Active Storage
    `avatar` attachment when present, otherwise a clean initial fallback.
    Presentation only — no new data. Locals:
      user  – the user to render (required)
      size  – diameter in px (default 40)
      ring  – ring colour (default light lavender)
      bg/fg – fallback background / text colour (default lavender / purple) %>
<%
  size ||= 40
  ring  = local_assigns.fetch(:ring, "#e3ddfb")
  bg    = local_assigns.fetch(:bg, "#EDE9FF")
  fg    = local_assigns.fetch(:fg, "#7C3AED")
  label = (user.username.presence || user.email).to_s
%>
<% if user.avatar.attached? %>
  <%= cl_image_tag user.avatar, alt: label, loading: "lazy", class: "ps-avatar",
        style: "width:#{size}px;height:#{size}px;border-radius:50%;object-fit:cover;box-shadow:0 0 0 2px #{ring};" %>
<% else %>
  <span class="ps-avatar ps-avatar--fallback"
        style="<%= "width:#{size}px;height:#{size}px;background:#{bg};color:#{fg};box-shadow:0 0 0 2px #{ring};font-size:#{(size * 0.42).round}px;" %>">
    <%= label.first.to_s.upcase %>
  </span>
<% end %>
