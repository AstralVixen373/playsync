<% content_for :title, "Settings" %>

<div class="settings-page">
  <h2>Settings</h2>

  <section class="settings-section">
    <h3>Account</h3>

    <div class="settings-subsection">
      <h4>Change email</h4>
      <p class="settings-description">Current: <strong><%= current_user.email %></strong></p>
      <%= form_with url: settings_email_path, method: :patch do |f| %>
        <div class="settings-field">
          <%= f.label :email, "New email" %>
          <%= f.email_field :email, name: "user[email]", class: "settings-input", required: true %>
        </div>
        <%= f.submit "Update email", class: "btn" %>
      <% end %>
    </div>

    <hr class="settings-divider">

    <div class="settings-subsection">
      <h4>Change password</h4>
      <%= form_with url: settings_password_path, method: :patch do |f| %>
        <div class="settings-field">
          <%= f.label :current_password, "Current password" %>
          <%= f.password_field :current_password, name: "user[current_password]", class: "settings-input", required: true %>
        </div>
        <div class="settings-field">
          <%= f.label :password, "New password" %>
          <%= f.password_field :password, name: "user[password]", class: "settings-input", required: true, autocomplete: "new-password" %>
        </div>
        <div class="settings-field">
          <%= f.label :password_confirmation, "Confirm new password" %>
          <%= f.password_field :password_confirmation, name: "user[password_confirmation]", class: "settings-input", required: true, autocomplete: "new-password" %>
        </div>
        <%= f.submit "Update password", class: "btn" %>
      <% end %>
    </div>

    <hr class="settings-divider">

    <div class="settings-subsection">
      <h4>Delete account</h4>
      <p class="settings-description">This action is permanent and cannot be undone.</p>
      <%= button_to "Delete my account",
            registration_path(:user),
            method: :delete,
            data: { turbo_confirm: "Are you sure? This cannot be undone." },
            class: "btn btn-danger" %>
    </div>
  </section>

  <section class="settings-section">
    <h3>Language</h3>
    <p class="settings-description">Choose your preferred language.</p>
    <div class="settings-placeholder">
      <!-- Language settings will be implemented here -->
    </div>
  </section>
</div>
