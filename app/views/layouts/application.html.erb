<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Playsync" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Playsync">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <title><%= meta_title %></title>
    <meta name="description" content="<%= meta_description %>">

    <!– Facebook Open Graph data –>
    <meta property="og:title" content="<%= meta_title %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= request.original_url %>">
    <meta property="og:image" content="<%= meta_image %>">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:description" content="<%= meta_description %>">
    <meta property="og:site_name" content="<%= meta_title %>">

    <!– Twitter Card data –>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="<%= DEFAULT_META["twitter_account"] %>">
    <meta name="twitter:title" content="<%= meta_title %>">
    <meta name="twitter:description" content="<%= meta_description %>">
    <meta name="twitter:creator" content="<%= DEFAULT_META["twitter_account"] %>">
    <meta name="twitter:image:src" content="<%= meta_image %>">

    <%= favicon_link_tag 'favicon.ico' %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #212529; }

      .alert { padding: 0.85rem 1rem; margin-bottom: 1rem; border-radius: 8px; font-size: 0.9rem; }
      .alert-notice { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
      .alert-alert  { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }

      .btn { display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; padding: 0.62rem 1.3rem; background: linear-gradient(135deg, #8B5CF6 0%, #6D28D9 100%); color: white; text-decoration: none; border-radius: 12px; border: 1px solid rgba(255,255,255,0.18); cursor: pointer; font-weight: 700; box-shadow: 0 6px 16px rgba(124,58,237,0.4), 0 2px 5px rgba(26,10,61,0.3), inset 0 1px 0 rgba(255,255,255,0.25); transition: transform 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease; }
      .btn:hover { color: white; transform: translateY(-1px); filter: brightness(1.05); box-shadow: 0 10px 22px rgba(124,58,237,0.5), 0 3px 8px rgba(26,10,61,0.35), inset 0 1px 0 rgba(255,255,255,0.3); }
      .btn:active { transform: translateY(0); filter: brightness(0.98); box-shadow: 0 3px 9px rgba(124,58,237,0.35), inset 0 1px 0 rgba(255,255,255,0.2); }
      .btn-secondary { background: #6c757d; border-color: transparent; box-shadow: 0 4px 10px rgba(0,0,0,0.12); }
      .btn-secondary:hover { background: #545b62; filter: none; box-shadow: 0 6px 14px rgba(0,0,0,0.18); }
      .btn-danger { background: #dc3545; border-color: transparent; box-shadow: 0 4px 10px rgba(220,53,69,0.3); }
      .btn-danger:hover { background: #c82333; filter: none; box-shadow: 0 6px 14px rgba(220,53,69,0.4); }

      /* Auth nav (unauthenticated users) */
      .ps-auth-nav { background: #fff; border-bottom: 1px solid #e0e0e0; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
      .ps-auth-nav a { color: #666; text-decoration: none; margin-left: 1rem; }
      .ps-auth-nav a:hover { color: #333; }
      .ps-auth-container { max-width: 900px; margin: 0 auto; padding: 2rem; }
    </style>
  </head>

  <body>
    <% if user_signed_in? %>
      <div class="ps-layout">

        <aside class="ps-sidebar">
          <%= link_to root_path, class: "ps-sidebar__logo" do %>
            <span class="ps-sidebar__logo-icon">
              <%= image_tag "playsync-logo.png", alt: "PlaySync", class: "ps-sidebar__logo-img" %>
            </span>
            <span class="ps-sidebar__logo-name"><strong>Play</strong>Sync</span>
          <% end %>
          <nav class="ps-sidebar__nav">
            <%= link_to posts_path, class: "ps-sidebar__link #{request.path == '/' || request.path.start_with?('/posts') ? 'active' : ''}" do %>
              <i class="fa-solid fa-bullhorn"></i>
              <span><%= t("nav.posts") %></span>
            <% end %>
            <%= link_to my_matches_path, class: "ps-sidebar__link #{request.path.start_with?('/my_matches') ? 'active' : ''}" do %>
              <i class="fa-solid fa-heart"></i>
              <span><%= t("nav.my_matches") %></span>
            <% end %>
            <%= link_to settings_path, class: "ps-sidebar__link #{request.path.start_with?('/settings') ? 'active' : ''}" do %>
              <i class="fa-solid fa-gear"></i>
              <span><%= t("nav.settings") %></span>
            <% end %>
          </nav>

          <div class="ps-sidebar__footer">
            <%= link_to edit_user_registration_path, class: "ps-sidebar__profile #{request.path == edit_user_registration_path ? 'active' : ''}" do %>
              <span class="ps-sidebar__avatar">
                <% if current_user.avatar.attached? %>
                  <%= image_tag current_user.avatar, alt: t("nav.profile") %>
                <% else %>
                  <%= (current_user.username.presence || current_user.email).first.upcase %>
                <% end %>
              </span>
              <span class="ps-sidebar__profile-text">
                <span class="ps-sidebar__profile-name"><%= current_user.username.presence || current_user.email %></span>
                <span class="ps-sidebar__profile-hint">
                  <%= t("nav.view_profile") %><i class="fa-solid fa-arrow-right"></i>
                </span>
              </span>
            <% end %>
          </div>
        </aside>

        <main class="ps-main">
          <%# Sticky header band: page title + (optional) page-specific header
              zone (filters/tabs) supplied via content_for(:page_header). Stays
              pinned while the cards below scroll inside .ps-main. %>
          <div class="ps-main__head">
            <div class="ps-topbar">
              <div class="ps-topbar__title">
                <%= yield(:page_title) %>
              </div>
              <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "ps-topbar__signout" do %>
                <i class="fa-solid fa-right-from-bracket"></i> <%= t("nav.sign_out") %>
              <% end %>
            </div>

            <% if content_for?(:page_header) %>
              <div class="ps-main__head-zone">
                <%= yield(:page_header) %>
              </div>
            <% end %>
          </div>

          <div class="ps-main__inner">
            <% if notice %>
              <div class="alert alert-notice"><%= notice %></div>
            <% end %>
            <% if alert %>
              <div class="alert alert-alert"><%= alert %></div>
            <% end %>

            <%= yield %>
          </div>
        </main>

      </div>
    <% else %>
      <nav class="ps-auth-nav">
        <div style="display: inline-flex; align-items: center; gap: 0.5rem;">
          <%= link_to root_path, style: "display: inline-flex; align-items: center; gap: 0.5rem; color: #333; text-decoration: none; font-weight: 700; font-size: 1.1rem;" do %>
            <%= image_tag "playsync-logo.png", alt: "PlaySync", style: "width: 30px; border-radius: 6px;" %>
            <span>PlaySync</span>
          <% end %>
        </div>
        <div>
          <%= link_to t("nav.sign_in"), new_user_session_path %>
          <%= link_to t("nav.sign_up"), new_user_registration_path %>
        </div>
      </nav>
      <div class="ps-auth-container">
        <% if notice %>
          <div class="alert alert-notice"><%= notice %></div>
        <% end %>
        <% if alert %>
          <div class="alert alert-alert"><%= alert %></div>
        <% end %>
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
