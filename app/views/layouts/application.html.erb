<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Playsync" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Playsync">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #212529; }

      .alert { padding: 0.85rem 1rem; margin-bottom: 1rem; border-radius: 8px; font-size: 0.9rem; }
      .alert-notice { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
      .alert-alert  { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }

      .btn { display: inline-block; padding: 0.5rem 1rem; background: #7C3AED; color: white; text-decoration: none; border-radius: 8px; border: none; cursor: pointer; font-weight: 600; }
      .btn:hover { background: #6D28D9; color: white; }
      .btn-secondary { background: #6c757d; }
      .btn-secondary:hover { background: #545b62; }
      .btn-danger { background: #dc3545; }
      .btn-danger:hover { background: #c82333; }

      /* Auth nav (unauthenticated users) */
      .ps-auth-nav { background: #fff; border-bottom: 1px solid #e0e0e0; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
      .ps-auth-nav a { color: #666; text-decoration: none; margin-left: 1rem; }
      .ps-auth-nav a:hover { color: #333; }
      .ps-auth-container { max-width: 900px; margin: 0 auto; padding: 2rem; }
    </style>
  </head>

  <body>
    <% if user_signed_in? %>
      <div class="ps-layout">

        <aside class="ps-sidebar">
          <%= link_to root_path, class: "ps-sidebar__logo" do %>
            <span class="ps-sidebar__logo-icon">
              <%= image_tag "playsync-logo.png", alt: "PlaySync", class: "ps-sidebar__logo-img" %>
            </span>
            <span class="ps-sidebar__logo-name"><strong>Play</strong>Sync</span>
          <% end %>
          <nav class="ps-sidebar__nav">
            <%= link_to posts_path, class: "ps-sidebar__link #{request.path == '/' || request.path.start_with?('/posts') ? 'active' : ''}" do %>
              <i class="fa-solid fa-bullhorn"></i>
              <span><%= t("nav.posts") %></span>
            <% end %>
            <%= link_to my_matches_path, class: "ps-sidebar__link #{request.path.start_with?('/my_matches') ? 'active' : ''}" do %>
              <i class="fa-solid fa-heart"></i>
              <span><%= t("nav.my_matches") %></span>
            <% end %>
            <%= link_to edit_user_registration_path, class: "ps-sidebar__link #{request.path == edit_user_registration_path ? 'active' : ''}" do %>
              <i class="fa-solid fa-user"></i>
              <span><%= t("nav.profile") %></span>
            <% end %>
            <%= link_to settings_path, class: "ps-sidebar__link #{request.path.start_with?('/settings') ? 'active' : ''}" do %>
              <i class="fa-solid fa-gear"></i>
              <span><%= t("nav.settings") %></span>
            <% end %>
          </nav>

          <div class="ps-sidebar__footer">
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "ps-sidebar__logout" do %>
              <i class="fa-solid fa-right-from-bracket"></i> <%= t("nav.sign_out") %>
            <% end %>
          </div>
        </aside>

        <main class="ps-main">
          <div class="ps-topbar">
            <div class="ps-topbar__title">
              <%= yield(:page_title) %>
            </div>
            <%= link_to new_post_path, class: "ps-topbar__cta" do %>
              <i class="fa-solid fa-bolt"></i> Create announcement
            <% end %>
          </div>

          <div class="ps-main__inner">
            <% if notice %>
              <div class="alert alert-notice"><%= notice %></div>
            <% end %>
            <% if alert %>
              <div class="alert alert-alert"><%= alert %></div>
            <% end %>

            <%= yield %>
          </div>
        </main>

      </div>
    <% else %>
      <nav class="ps-auth-nav">
        <div style="display: inline-flex; align-items: center; gap: 0.5rem;">
          <%= link_to root_path, style: "display: inline-flex; align-items: center; gap: 0.5rem; color: #333; text-decoration: none; font-weight: 700; font-size: 1.1rem;" do %>
            <%= image_tag "playsync-logo.png", alt: "PlaySync", style: "width: 30px; border-radius: 6px;" %>
            <span>PlaySync</span>
          <% end %>
        </div>
        <div>
          <%= link_to t("nav.sign_in"), new_user_session_path %>
          <%= link_to t("nav.sign_up"), new_user_registration_path %>
        </div>
      </nav>
      <div class="ps-auth-container">
        <% if notice %>
          <div class="alert alert-notice"><%= notice %></div>
        <% end %>
        <% if alert %>
          <div class="alert alert-alert"><%= alert %></div>
        <% end %>
        <%= yield %>
      </div>
    <% end %>
  </body>
</html>
