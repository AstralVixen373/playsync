<%# Per-author colour is preserved exactly: random_color_for(user) keeps each
    participant's distinct {light, dark} pair. The avatar ring reuses the same
    colour so the speaker is identifiable at a glance. %>
<% colors = random_color_for(message.user) %>
<div class="ps-msg" data-scroll-target="message">
  <%= render "shared/avatar", user: message.user, size: 40,
        ring: colors[:dark], bg: colors[:light], fg: colors[:dark] %>

  <div class="ps-msg__bubble"
       style="background: <%= colors[:light] %>; border-left: 3px solid <%= colors[:dark] %>;">
    <div class="ps-msg__head" id="<%= dom_id(message) %>">
      <strong class="ps-msg__author" style="color: <%= colors[:dark] %>;"><%= message.user.username %></strong>
      <span class="ps-msg__time"><%= message.created_at.strftime("%H:%M") %></span>
    </div>
    <p class="ps-msg__text"><%= message.content %></p>
  </div>
</div>
