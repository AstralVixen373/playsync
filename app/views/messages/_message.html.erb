<div class="message-bubble <%= current_user == message.user ? "message-bubble--own" : "" %>">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
    <strong><%= message.user.username %></strong>
    <span style="font-size: 0.85rem; color: #adb5bd;"><%= message.created_at.strftime("%H:%M") %></span>
  </div>
  <p style="color: #212529; margin: 0;"><%= message.content %></p>
</div>
