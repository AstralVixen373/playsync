<div style="margin-bottom: 1rem; padding: 0.75rem; background: <%= random_color_for(message.user)[:light] %>; border-radius: 4px; border-left: 3px solid <%= random_color_for(message.user)[:dark] %>;" data-scroll-target="message">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;" id="<%= dom_id(message) %>">
    <strong><%= message.user.username %></strong>
    <span style="font-size: 0.85rem; color: rgba(33, 37, 41, .5);"><%= message.created_at.strftime("%H:%M") %></span>
  </div>
  <p style="color: #212529; margin: 0;"><%= message.content %></p>
</div>
