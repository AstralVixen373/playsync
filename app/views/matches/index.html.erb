<% content_for :title, t("matches.index.title") %>
<% content_for :head_banner, "matches" %>

<% content_for :page_title do %>
  <h1><%= t("matches.index.title") %></h1>
  <p><%= t("matches.index.subtitle") %></p>
<% end %>

<%# ── In-view partitioning ──────────────────────────────────────────────────
    The controller hands us every match (owned + joined) as @posts plus the set
    of favourited ids. Tabs are derived here — no extra queries, no controller
    change. `tab` is read from the URL so the active tab survives Turbo reloads
    (the controller safely ignores the unknown :tab param). %>
<%
  tab = params[:tab].to_s
  tab = "current" unless %w[current favourites finished].include?(tab)

  all_matches    = @posts.to_a
  open_matches     = all_matches.select(&:open?)
  finished_matches = all_matches.reject(&:open?)
  favourite_matches = all_matches.select { |p| @favourited_ids.include?(p.id) }

  visible_matches = case tab
                    when "favourites" then favourite_matches
                    when "finished"   then finished_matches
                    else                   open_matches
                    end

  # The game currently filtered on, resolved from already-loaded matches (no
  # extra query) so the search pill can show it as a chip. Single value to match
  # the controller's `params[:game_id]`.
  selected_game = all_matches.map(&:game).find { |g| g.id.to_s == params[:game_id].to_s }
%>

<% content_for :page_header do %>
<div class="ps-find">

  <%# ── Tabs ──────────────────────────────────────────────────────────────── %>
  <nav class="ps-tabs">
    <%= link_to my_matches_path(tab: "current"), class: "ps-tab #{'is-active' if tab == 'current'}" do %>
      <%= t("matches.index.tabs.current") %>
      <span class="ps-tab__count"><%= open_matches.size %></span>
    <% end %>
    <%= link_to my_matches_path(tab: "favourites"), class: "ps-tab #{'is-active' if tab == 'favourites'}" do %>
      <i class="fa-solid fa-heart"></i> <%= t("matches.index.tabs.favourites") %>
      <span class="ps-tab__count"><%= favourite_matches.size %></span>
    <% end %>
    <%= link_to my_matches_path(tab: "finished"), class: "ps-tab #{'is-active' if tab == 'finished'}" do %>
      <%= t("matches.index.tabs.finished") %>
      <span class="ps-tab__count"><%= finished_matches.size %></span>
    <% end %>
  </nav>

  <%# ── Filters ───────────────────────────────────────────────────────────── %>
  <%# Same components as the Annonces board (game-search pill + shared/multiselect
      with its flag/platform icons), wired to the single-value params the matches
      controller already reads (game_id / platform / post_type / language).
      `single: true` makes each multiselect behave like a radio. Auto-submit on change. %>
  <section class="ps-find__search">
    <span class="ps-find__label">
      <i class="fa-solid fa-magnifying-glass"></i> <%= t("matches.index.filter_label") %>
    </span>

    <%= form_with url: my_matches_path, method: :get,
                  data: { controller: "form", action: "change->form#submit" } do |f| %>
      <%= hidden_field_tag :tab, tab %>

      <div class="ps-filter-bar">

        <%# Game search — same pill + autocomplete as the Annonces board. The
            chips container's `data-field` is the single `game_id` the matches
            controller filters on (Annonces uses the multi `game_ids[]`). %>
        <div class="ps-filter-game-wrapper">
          <input type="text" id="filter-game-search"
                 placeholder="🎮 <%= t('matches.index.all_games') %>"
                 autocomplete="off"
                 class="ps-filter-pill-input">
          <div id="filter-game-results"></div>
        </div>

        <%= render "shared/multiselect", name: "platform",  options: Post::PLATFORMS, selected: params[:platform],  placeholder: "🖥️ #{t('matches.index.all_platforms')}",  single: true %>
        <%= render "shared/multiselect", name: "post_type", options: Post::TYPES,     selected: params[:post_type], placeholder: "👥 #{t('matches.index.all_types')}",      single: true %>
        <%= render "shared/multiselect", name: "language",  options: Post::LANGUAGES, selected: params[:language],   placeholder: "🌐 #{t('matches.index.all_languages')}",  single: true %>

        <% if params.values_at(:game_id, :platform, :post_type, :language).any?(&:present?) %>
          <%= link_to t("matches.index.reset"), my_matches_path(tab: tab), class: "ps-filter-reset" %>
        <% end %>
      </div>

      <%# Selected game chip — rendered server-side like the Annonces board so it
          survives reloads; the JS picker auto-submits on add/remove. %>
      <div id="filter-game-chips" data-field="game_id" class="ps-game-chips" style="margin-bottom: 0;">
        <% if selected_game %>
          <span class="ps-game-chip">
            <%= hidden_field_tag "game_id", selected_game.id %>
            <%= selected_game.name %>
            <button type="button" class="game-chip-remove">×</button>
          </span>
        <% end %>
      </div>
    <% end %>
  </section>

</div>
<% end %>

<%# ── Board + favourites rail ────────────────────────────────────────────── %>
<div class="ps-matches-layout">

  <div class="ps-matches-main">
    <% if visible_matches.any? %>
      <div class="ps-cards-grid">
        <% visible_matches.each do |post| %>
          <%= render "matches/match",
                post: post,
                current_user: current_user,
                favourited: @favourited_ids.include?(post.id) %>
        <% end %>
      </div>
    <% else %>
      <p class="ps-empty"><%= t("matches.index.empty.#{tab}") %></p>
    <% end %>
  </div>

  <%# Right rail — compact favourites list. Reuses existing routes only. %>
  <aside class="ps-fav-rail">
    <h2 class="ps-fav-rail__title"><%= t("matches.index.favourites_sidebar") %></h2>

    <% if favourite_matches.any? %>
      <ul class="ps-fav-list">
        <% favourite_matches.each do |post| %>
          <li class="ps-fav-item">
            <%= link_to post_path(post), class: "ps-fav-item__link" do %>
              <span class="ps-fav-item__thumb <%= 'ps-fav-item__thumb--art' if post.game.cover? %>">
                <% if post.game.cover? %>
                  <%= image_tag post.game.cover_url, alt: post.game.name, loading: "lazy" %>
                <% else %>
                  <%= post.game.name.first.upcase %>
                <% end %>
              </span>
              <span class="ps-fav-item__text">
                <span class="ps-fav-item__name"><%= post.title %></span>
                <span class="ps-fav-item__game"><%= post.game.name %></span>
              </span>
            <% end %>
            <%= button_to post_favourite_path(post), method: :delete,
                  class: "ps-fav-btn is-active", title: t("matches.index.unfavourite") do %>
              <i class="fa-solid fa-heart"></i>
            <% end %>
          </li>
        <% end %>
      </ul>

      <% if tab != "favourites" %>
        <%= link_to t("matches.index.see_all_favourites"),
              my_matches_path(tab: "favourites"), class: "ps-fav-rail__more" %>
      <% end %>
    <% else %>
      <p class="ps-fav-rail__empty"><%= t("matches.index.no_favourites") %></p>
    <% end %>
  </aside>

</div>
