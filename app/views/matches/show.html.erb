<% content_for :title, @post.title %>
<%= link_to t("matches.show.back"), my_matches_path, style: "color: rgba(33, 37, 41, .75); text-decoration: none; display: inline-block; margin-bottom: 1.5rem;" %>

<div style="display: grid; grid-template-columns: 1fr 2fr; gap: 2rem;">
  <!-- Post Details -->
  <div style="background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 2rem;">
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;">
      <h1 style="margin: 0;"><%= @post.title %></h1>
      <% if @post.open? %>
        <span style="background: #d4edda; color: #155724; padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.8rem; font-weight: 600;">Open</span>
      <% else %>
        <span style="background: #e2e3e5; color: #383d41; padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.8rem; font-weight: 600;">Finished</span>
      <% end %>
    </div>

    <div style="background: #f8f9fa; padding: 1.5rem; border-radius: 4px; margin-bottom: 1.5rem;">
      <p><strong>👤 <%= t("matches.show.posted_by") %>:</strong>

        <%= @post.user.username.presence || @post.user.email %>
        <% if @post.user == current_user %>
          <span style="background: #007bff; color: white; font-size: 0.75rem; padding: 0.1rem 0.4rem; border-radius: 4px; margin-left: 0.4rem;"><%= t("matches.show.you") %></span>
        <% end %>
      </p>
      <p><strong>🎮 <%= t("matches.show.game") %>:</strong> <%= @post.game.name %></p>
      <p><strong>🖥️ <%= t("matches.show.platform") %>:</strong> <%= @post.platforms.join(", ") %></p>
      <p><strong>🌐 <%= t("matches.show.language") %>:</strong> <%= @post.language %></p>
      <p><strong>👥 <%= t("matches.show.type") %>:</strong> <%= @post.post_type %></p>
      <p><strong>🎯 <%= t("matches.show.slots") %>:</strong> <%= @post.slot %></p>
    </div>

    <% if @post.chat&.users&.any? %>
      <h3 style="margin-bottom: 1rem;">👥 <%= t("matches.show.participants") %></h3>
      <div style="background: #f8f9fa; padding: 1rem; border-radius: 4px;">
        <% @post.chat.users.each do |user| %>
          <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid #dee2e6;">
            <p style="margin: 0;"><%= user.username.presence || user.email %></p>
            <% if @post.user == current_user && user != current_user %>
              <%= button_to t("matches.show.kick"), kick_post_path(@post, user_id: user.id),
                    method: :delete,
                    data: { turbo_confirm: t("matches.show.kick_confirm") },
                    style: "background: #dc3545; color: white; border: none; border-radius: 4px; padding: 0.2rem 0.6rem; font-size: 0.8rem; cursor: pointer;" %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Chat -->
  <div style="background: #fff; border: 1px solid #dee2e6; border-radius: 8px; padding: 2rem; display: flex; flex-direction: column;">
    <h2 style="margin-bottom: 1rem;">💬 <%= t("matches.show.chat") %></h2>

    <div style="flex: 1; overflow-y: auto; background: #f8f9fa; padding: 1rem; border-radius: 4px; margin-bottom: 1rem; max-height: 500px;">
      <% if @post.chat&.messages&.any? %>
        <% @post.chat.messages.each do |message| %>
          <%= render "messages/message", message: message %>
        <% end %>
      <% else %>
        <p style="color: rgba(33, 37, 41, .5); text-align: center;"><%= t("matches.show.no_messages") %></p>
      <% end %>
    </div>
  </div>
</div>
