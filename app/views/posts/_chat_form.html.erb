<%# Message composer. Same model, route and submit — restyled only. %>
<%= form_with model: [chat, message], url: chat_messages_path(chat), class: "ps-chat-form" do |f| %>
  <%= f.text_area :content, placeholder: t("posts.show.type_message"),
        class: "ps-chat-form__input", rows: 1 %>
  <%= f.submit t("posts.show.send"), class: "btn ps-chat-form__send" %>
<% end %>
