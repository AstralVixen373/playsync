<%# Renders one post card. `current_user` is passed as a local (nil in Turbo
    broadcasts) so this partial never relies on request/Pundit state. %>
<% member  = current_user && post.member?(current_user) %>
<% owner   = current_user && post.user == current_user %>
<% expired = post.created_at < 1.hour.ago %>
<% full    = post.full? %>

<div id="<%= dom_id(post) %>" class="ps-card <%= 'ps-card--expired' if expired %> <%= 'ps-card--full' if full && !expired %>">

  <% if expired %>
    <div class="ps-card__banner ps-card__banner--expired">EXPIRED</div>
  <% elsif full %>
    <div class="ps-card__banner ps-card__banner--full">FULL</div>
  <% end %>

  <div class="ps-card__cover">
    <%= post.game.name.first.upcase %>
  </div>

  <div class="ps-card__body">
    <div class="ps-card__top">
      <span class="ps-badge ps-badge--<%= post.post_type.downcase %>"><%= post.post_type %></span>
      <span class="ps-status-badge ps-status-badge--<%= post.status %>"><%= post.status.capitalize %></span>
    </div>
    <h3 class="ps-card__title"><%= post.title %></h3>
    <p class="ps-card__game"><%= post.game.name %></p>
    <div class="ps-card__meta">
      <%= render "posts/slots", post: post %>
      <span>·</span>
      <span><%= post.platforms.join(", ") %></span>
      <span>·</span>
      <span><%= time_ago_in_words(post.created_at) %> ago</span>
    </div>
  </div>

  <div class="ps-card__actions">
    <% if member || owner %>
      <%= link_to post_path(id: post.id), class: "ps-card__chevron" do %>
        <i class="fa-solid fa-chevron-right"></i>
      <% end %>
    <% elsif current_user %>
      <%= button_to join_post_path(post), method: :post, class: "ps-card__chevron ps-card__chevron--join" do %>
        <i class="fa-solid fa-arrow-right-to-bracket"></i>
      <% end %>
    <% else %>
      <%= link_to post_path(id: post.id), class: "ps-card__chevron" do %>
        <i class="fa-solid fa-chevron-right"></i>
      <% end %>
    <% end %>

    <% if owner %>
      <div class="ps-card__owner-actions">
        <%= link_to "Edit", edit_post_path(id: post.id), class: "ps-edit" %>
        <%= link_to "Del", post_path(post.id), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "ps-delete" %>
      </div>
    <% end %>
  </div>

</div>
