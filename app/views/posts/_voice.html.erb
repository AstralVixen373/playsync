<%# WebRTC voice room. Every data-* attribute, target and action is unchanged —
    only the presentation is restyled into a premium lavender banner. %>
<div data-controller="voice"
     data-voice-post-id-value="<%= post.id %>"
     data-voice-user-id-value="<%= current_user.id %>"
     class="ps-room__voice">
  <span class="ps-room__voice-icon"><i class="fa-solid fa-microphone"></i></span>

  <div class="ps-room__voice-text">
    <span class="ps-room__voice-title"><%= t("posts.show.vocal") %></span>
    <span class="ps-room__voice-sub"><%= t("posts.show.join_voice") %></span>
  </div>

  <div class="ps-room__voice-controls">
    <button type="button" class="btn"
            data-voice-target="joinButton" data-action="voice#join">
      <i class="fa-solid fa-microphone">
        <%= t("posts.voice.join") %>
      </i>
    </button>
    <button type="button" class="btn btn-secondary"
            data-voice-target="muteButton" data-action="voice#toggleMute"
            style="display: none;">
      🔇 <%= t("posts.voice.mute") %>
    </button>
    <button type="button" class="btn btn-danger"
            data-voice-target="leaveButton" data-action="voice#leave"
            style="display: none;">
      <%= t("posts.voice.leave") %>
    </button>
    <span data-voice-target="status" class="ps-room__voice-status"></span>
  </div>

  <div data-voice-target="audios"></div>
</div>
