<div id="posts_list">
  <% if posts.any? %>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
      <% posts.each do |post| %>
        <%= render "posts/post", post: post, current_user: current_user %>
      <% end %>
    </div>
  <% else %>
    <p style="text-align: center; color: #999; padding: 3rem;">No posts available right now. <%= link_to "Create one!", new_post_path %></p>
  <% end %>
</div>
