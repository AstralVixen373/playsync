<%= turbo_stream_from @post %>
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
  <!-- Post Details -->
  <div style="background: var(--bs-body-bg); border: 1px solid var(--bs-border-color); border-radius: 8px; padding: 2rem;">
    <h1 style="margin-bottom: 1rem;"><%= @post.title %></h1>

    <div style="background: var(--bs-tertiary-bg); padding: 1.5rem; border-radius: 4px; margin-bottom: 1.5rem;">
      <p><strong>👤 <%= t("posts.show.posted_by") %>:</strong> <%= @post.user.username.presence || @post.user.email %></p>
      <p><strong>🎮 <%= t("posts.show.game") %>:</strong> <%= @post.game.name %></p>
      <p><strong>🖥️ <%= t("posts.show.platform") %>:</strong> <%= @post.platforms.join(", ") %></p>
      <p><strong>🌐 <%= t("posts.show.language") %>:</strong> <%= @post.language %></p>
      <p><strong>👥 <%= t("posts.show.type") %>:</strong> <%= @post.post_type %></p>
      <p><%= render "posts/slots", post: @post %></p>
      <p style="color: var(--bs-tertiary-color); font-size: 0.9rem;"><strong>📅 <%= t("posts.show.created") %>:</strong> <%= @post.created_at.strftime("%b %d, %Y") %></p>
    </div>

    <h3 style="margin-bottom: 1rem;">👥 <%= t("posts.show.participants") %></h3>
    <div style="background: var(--bs-tertiary-bg); padding: 1rem; border-radius: 4px;">
      <% if @chat.users.any? %>
        <% @chat.users.each do |user| %>
          <div style="padding: 0.5rem 0; border-bottom: 1px solid var(--bs-border-color);">
            <p style="margin: 0;"><%= user.username %></p>
          </div>
        <% end %>
      <% else %>
        <p style="color: var(--bs-tertiary-color);"><%= t("posts.show.no_participants") %></p>
      <% end %>
    </div>

    <% if user_signed_in? %>
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1.5rem;">
        <% if @post.user == current_user %>
          <span style="align-self: center; color: var(--bs-secondary-color);"><%= t("posts.show.you_created") %></span>
        <% elsif @is_member %>
          <%= button_to t("posts.show.leave_match"), leave_post_path(@post), method: :delete, class: "btn btn-secondary", data: { turbo_confirm: t("posts.show.leave_confirm") } %>
        <% elsif @post.full? %>
          <button class="btn" disabled style="opacity: 0.6; cursor: not-allowed;"><%= t("posts.show.full") %></button>
        <% else %>
          <%= button_to t("posts.show.join_match"), join_post_path(@post), method: :post, class: "btn" %>
        <% end %>

        <% if policy(@post).edit? %>
          <%= link_to t("posts.show.edit"), edit_post_path(id: @post.id), class: "btn btn-secondary" %>
        <% end %>
        <% if policy(@post).destroy? %>
          <%= link_to t("posts.show.delete"), post_path(@post), data: { turbo_method: :delete, turbo_confirm: t("posts.show.delete_confirm") }, class: "btn btn-danger" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Chat Section -->
  <div style="background: var(--bs-body-bg); border: 1px solid var(--bs-border-color); border-radius: 8px; padding: 2rem; display: flex; flex-direction: column;">
    <h2 style="margin-bottom: 1rem;">💬 <%= t("posts.show.chat") %></h2>

    <% if @is_member && @chat %>
      <%= render "posts/voice", post: @post %>

      <div style="flex: 1; overflow-y: auto; background: var(--bs-tertiary-bg); padding: 1rem; border-radius: 4px; margin-bottom: 1rem; max-height: 400px;">
        <% if @chat.messages.any? %>
          <% @chat.messages.each do |message| %>
            <%= render "messages/message", message: message %>
          <% end %>
        <% else %>
          <p style="color: var(--bs-tertiary-color); text-align: center;"><%= t("posts.show.no_messages") %></p>
        <% end %>
      </div>

      <%= form_with model: [@chat, @message], url: chat_messages_path(@chat) do |f| %>
        <div style="display: flex; gap: 0.5rem;">
          <%= f.text_area :content, placeholder: t("posts.show.type_message"), style: "flex: 1; padding: 0.5rem; border: 1px solid var(--bs-border-color); border-radius: 4px; resize: none; height: 60px; background: var(--bs-body-bg); color: var(--bs-body-color);" %>
          <%= f.submit t("posts.show.send"), class: "btn", style: "align-self: flex-end;" %>
        </div>
      <% end %>
    <% else %>
      <p style="color: var(--bs-tertiary-color); text-align: center; padding: 2rem;">
        <% if @post.full? %>
          <%= t("posts.show.full_chat") %>
        <% else %>
          <%= t("posts.show.join_to_chat") %>
        <% end %>
      </p>
    <% end %>
  </div>
</div>
