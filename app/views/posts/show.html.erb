<%= turbo_stream_from @post %>
<%= turbo_stream_from @chat %>

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
  <!-- Post Details -->
  <div style="background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 2rem;">
    <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem;">
      <h1 style="margin: 0;"><%= @post.title %></h1>
      <% if @post.open? %>
        <span style="background: #d4edda; color: #155724; padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.8rem; font-weight: 600;">Open</span>
      <% else %>
        <span style="background: #e2e3e5; color: #383d41; padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.8rem; font-weight: 600;">Finished</span>
      <% end %>
    </div>

    <div style="background: #f9f9f9; padding: 1.5rem; border-radius: 4px; margin-bottom: 1.5rem;">
      <p><strong>👤 <%= t("posts.show.posted_by") %>:</strong> <%= @post.user.username.presence || @post.user.email %></p>
      <p><strong>🎮 <%= t("posts.show.game") %>:</strong> <%= @post.game.name %></p>
      <p><strong>🖥️ <%= t("posts.show.platform") %>:</strong> <%= platform_list(@post.platforms) %></p>
      <p><strong>🌐 <%= t("posts.show.language") %>:</strong> <%= @post.language %></p>
      <p><strong>👥 <%= t("posts.show.type") %>:</strong> <%= @post.post_type %></p>
      <p><%= render "posts/slots", post: @post %></p>
      <p style="color: rgba(33, 37, 41, .5); font-size: 0.9rem;"><strong>📅 <%= t("posts.show.created") %>:</strong> <%= @post.created_at.strftime("%b %d, %Y") %></p>
    </div>

    <h3 style="margin-bottom: 1rem;">👥 <%= t("posts.show.participants") %></h3>
    <div style="background: #f8f9fa; padding: 1rem; border-radius: 4px;">
      <% if @chat.users.any? %>
        <% @chat.users.each do |user| %>
          <div style="padding: 0.5rem 0; border-bottom: 1px solid #dee2e6;">
            <p style="margin: 0;"><%= user.username %></p>
          </div>
        <% end %>
      <% else %>
        <p style="color: rgba(33, 37, 41, .5);"><%= t("posts.show.no_participants") %></p>
      <% end %>
    </div>

    <% if user_signed_in? %>
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1.5rem;">
        <% if @post.user == current_user %>
          <span style="align-self: center; color: #666;"><%= t("posts.show.you_created") %></span>
          <% if @post.open? && policy(@post).finish? %>
            <%= button_to "Mark as finished", finish_post_path(@post), method: :patch, class: "btn btn-secondary", data: { turbo_confirm: "Mark this match as finished?" } %>
          <% end %>
        <% elsif @is_member %>
          <%= button_to t("posts.show.leave_match"), leave_post_path(@post), method: :delete, class: "btn btn-secondary", data: { turbo_confirm: t("posts.show.leave_confirm") } %>
        <% elsif @post.full? %>
          <button class="btn" disabled style="opacity: 0.6; cursor: not-allowed;"><%= t("posts.show.full") %></button>
        <% else %>
          <%= button_to t("posts.show.join_match"), join_post_path(@post), method: :post, class: "btn" %>
        <% end %>

        <% if policy(@post).edit? %>
          <%= link_to t("posts.show.edit"), edit_post_path(id: @post.id), class: "btn btn-secondary" %>
        <% end %>
        <% if policy(@post).destroy? %>
          <%= link_to t("posts.show.delete"), post_path(@post), data: { turbo_method: :delete, turbo_confirm: t("posts.show.delete_confirm") }, class: "btn btn-danger" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Chat Section -->
  <div style="background: #fff; border: 1px solid #dee2e6; border-radius: 8px; padding: 2rem; display: flex; flex-direction: column;">
    <h2 style="margin-bottom: 1rem;">💬 <%= t("posts.show.chat") %></h2>

    <% if @is_member && @chat %>
      <%= render "posts/voice", post: @post %>

      <div style="flex: 1; overflow-y: auto; background: #f9f9f9; padding: 1rem; border-radius: 4px; margin-bottom: 1rem; max-height: 400px;" id="messages" data-controller="scroll" data-scroll-target="messages">
        <% if @chat.messages.any? %>
          <% @chat.messages.each do |message| %>
            <%= render "messages/message", message: message %>
          <% end %>
        <% else %>
          <p style="color: rgba(33, 37, 41, .5); text-align: center;"><%= t("posts.show.no_messages") %></p>
        <% end %>
      </div>

      <div id="form_container">
        <%= render "posts/chat_form", chat: @chat, message: @message %>
      </div>
    <% else %>
      <p style="color: rgba(33, 37, 41, .5); text-align: center; padding: 2rem;">
        <% if @post.full? %>
          <%= t("posts.show.full_chat") %>
        <% else %>
          <%= t("posts.show.join_to_chat") %>
        <% end %>
      </p>
    <% end %>
  </div>
</div>
