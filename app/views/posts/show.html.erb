<%= turbo_stream_from @post %>
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
  <!-- Post Details -->
  <div style="background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 2rem;">
    <h1 style="margin-bottom: 1rem;"><%= @post.title %></h1>

    <div style="background: #f9f9f9; padding: 1.5rem; border-radius: 4px; margin-bottom: 1.5rem;">
      <p><strong>👤 Posted by:</strong> <%= @post.user.username.presence || @post.user.email %></p>
      <p><strong>🎮 Game:</strong> <%= @post.game.name %></p>
      <p><strong>🖥️ Platform:</strong> <%= @post.platforms.join(", ") %></p>
      <p><strong>🌐 Language:</strong> <%= @post.language %></p>
      <p><strong>👥 Type:</strong> <%= @post.post_type %></p>
      <p><%= render "posts/slots", post: @post %></p>
      <p style="color: #999; font-size: 0.9rem;"><strong>📅 Created:</strong> <%= @post.created_at.strftime("%b %d, %Y") %></p>
    </div>

        <h3 style="margin-bottom: 1rem;">👥 Participants</h3>
    <div style="background: #f9f9f9; padding: 1rem; border-radius: 4px;">
      <% if @chat.users.any? %>
        <% @chat.users.each do |user| %>
          <div style="padding: 0.5rem 0; border-bottom: 1px solid #e0e0e0;">
            <p style="margin: 0;"><%= user.username %></p>
          </div>
        <% end %>
      <% else %>
        <p style="color: #999;">No participants yet</p>
      <% end %>
    </div>

    <% if user_signed_in? %>
      <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
        <% if @post.user == current_user %>
          <span style="align-self: center; color: #666;">You created this match.</span>
        <% elsif @is_member %>
          <%= button_to "Leave match", leave_post_path(@post), method: :delete, class: "btn btn-secondary", data: { turbo_confirm: "Leave this match?" } %>
        <% elsif @post.full? %>
          <button class="btn" disabled style="opacity: 0.6; cursor: not-allowed;">Full</button>
        <% else %>
          <%= button_to "Join match", join_post_path(@post), method: :post, class: "btn" %>
        <% end %>

        <% if policy(@post).edit? %>
          <%= link_to "Edit", edit_post_path(id: @post.id), class: "btn btn-secondary" %>
        <% end %>
        <% if policy(@post).destroy? %>
          <%= link_to "Delete", post_path(@post), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-danger" %>
        <% end %>
      </div>
    <% end %>
  </div>


  <!-- Chat Section -->
  <div style="background: white; border: 1px solid #e0e0e0; border-radius: 8px; padding: 2rem; display: flex; flex-direction: column;">
    <h2 style="margin-bottom: 1rem;">💬 Chat</h2>

    <% if @is_member && @chat %>
      <%= render "posts/voice", post: @post %>

      <div style="flex: 1; overflow-y: auto; background: #f9f9f9; padding: 1rem; border-radius: 4px; margin-bottom: 1rem; max-height: 400px;">
        <% if @chat.messages.any? %>
          <% @chat.messages.each do |message| %>
            <%= render "messages/message", message: message %>
          <% end %>
        <% else %>
          <p style="color: #999; text-align: center;">No messages yet</p>
        <% end %>
      </div>

      <%= form_with model: [@chat, @message], url: chat_messages_path(@chat) do |f| %>
        <div style="display: flex; gap: 0.5rem;">
          <%= f.text_area :content, placeholder: "Type a message...", style: "flex: 1; padding: 0.5rem; border: 1px solid #e0e0e0; border-radius: 4px; resize: none; height: 60px;" %>
          <%= f.submit "Send", class: "btn", style: "align-self: flex-end;" %>
        </div>
      <% end %>
    <% else %>
      <p style="color: #999; text-align: center; padding: 2rem;">
        <% if @post.full? %>
          This match is full — chat is reserved for its members.
        <% else %>
          Join the match to access the chat.
        <% end %>
      </p>
    <% end %>
  </div>
</div>
