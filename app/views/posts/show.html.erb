<% content_for :title, @post.title %>
<% content_for :head_banner, "room" %>

<%# Standard page header (same sticky band as Posts / My Matches / Settings):
    title + status live in the topbar, the match actions live in the header
    zone — so the whole header stays pinned and proportioned while the cards
    below scroll. %>
<% content_for :page_title do %>
  <div class="ps-room__head-title">
    <h1><%= @post.title %></h1>
    <% if @post.open? %>
      <span class="ps-status ps-status--open"><span class="ps-status__dot"></span>Open</span>
    <% else %>
      <span class="ps-status ps-status--finished"><span class="ps-status__dot"></span>Finished</span>
    <% end %>
  </div>
  <p><%= @post.user.username.presence || @post.user.email %> · <%= @post.game.name %></p>
<% end %>

<% if user_signed_in? %>
  <% content_for :page_header do %>
    <%# Match actions — unchanged handlers / routes / confirms. %>
    <div class="ps-room__head-actions" id="post_footer">
      <% if @post.user == current_user %>
        <% if @post.open? && policy(@post).finish? %>
          <%= button_to "Mark as finished", finish_post_path(@post), method: :patch, class: "btn btn-secondary", data: { turbo_confirm: "Mark this match as finished?" } %>
        <% end %>
      <% elsif @is_member %>
        <%= button_to t("posts.show.leave_match"), leave_post_path(@post), method: :delete, class: "btn btn-secondary", data: { turbo_confirm: t("posts.show.leave_confirm") } %>
      <% elsif @post.kicked?(current_user) %>
        <%= render "posts/kicked_out" %>
      <% elsif @post.full? %>
        <button class="btn" disabled style="opacity: 0.6; cursor: not-allowed;"><%= t("posts.show.full") %></button>
      <% else %>
        <%= button_to t("posts.show.join_match"), join_post_path(@post), method: :post, class: "btn" %>
      <% end %>

      <% if policy(@post).edit? %>
        <%= link_to t("posts.show.edit"), edit_post_path(id: @post.id), class: "btn btn-secondary" %>
      <% end %>
      <% if policy(@post).destroy? %>
        <%= link_to t("posts.show.delete"), post_path(@post), data: { turbo_method: :delete, turbo_confirm: t("posts.show.delete_confirm") }, class: "btn btn-danger" %>
      <% end %>
    </div>
  <% end %>
<% end %>

<%= turbo_stream_from @post %>
<%= turbo_stream_from @chat %>
<%= turbo_stream_from "user_chat" %>
<%= turbo_stream_from current_user %>

<style>
.kick_button_<%= current_user.id %> {
  display: none;
}
<% if @post.user != current_user %>
.kick_button {
  display: none;
}
<% end %>
</style>

<div class="ps-room">

  <%# ── Two-column body ─────────────────────────────────────────────────── %>
  <div class="ps-room__grid">

    <%# Left column — session details + participants %>
    <div class="ps-room__col">

      <div class="ps-room__card">
        <div class="ps-room__card-head">
          <h2 class="ps-room__card-title"><i class="fa-solid fa-circle-info"></i><%= t("posts.show.session_details") %></h2>
        </div>

        <div class="ps-room__details">
          <div class="ps-room__detail">
            <span class="ps-room__detail-icon"><i class="fa-solid fa-user"></i></span>
            <div class="ps-room__detail-body">
              <span class="ps-room__detail-label"><%= t("posts.show.posted_by") %></span>
              <span class="ps-room__detail-value">
                <%= @post.user.username.presence || @post.user.email %>
                <% if @post.user == current_user %>
                  <span class="ps-room__you"><%= t("posts.show.you") %></span>
                <% end %>
              </span>
            </div>
          </div>

          <div class="ps-room__detail">
            <span class="ps-room__detail-icon"><i class="fa-solid fa-gamepad"></i></span>
            <div class="ps-room__detail-body">
              <span class="ps-room__detail-label"><%= t("posts.show.game") %></span>
              <span class="ps-room__detail-value"><%= @post.game.name %></span>
            </div>
          </div>

          <div class="ps-room__detail ps-room__detail--wide">
            <span class="ps-room__detail-icon"><i class="fa-solid fa-display"></i></span>
            <div class="ps-room__detail-body">
              <span class="ps-room__detail-label"><%= t("posts.show.platform") %></span>
              <div class="ps-room__platforms">
                <% Array(@post.platforms).each do |name| %>
                  <span class="ps-chip"><%= platform_icon(name, size: 14) %><%= name %></span>
                <% end %>
              </div>
            </div>
          </div>

          <div class="ps-room__detail">
            <span class="ps-room__detail-icon"><i class="fa-solid fa-globe"></i></span>
            <div class="ps-room__detail-body">
              <span class="ps-room__detail-label"><%= t("posts.show.language") %></span>
              <span class="ps-room__detail-value"><%= option_icon(@post.language, size: 15) %><%= language_label(@post.language) %></span>
            </div>
          </div>

          <div class="ps-room__detail">
            <span class="ps-room__detail-icon"><i class="fa-solid fa-bolt"></i></span>
            <div class="ps-room__detail-body">
              <span class="ps-room__detail-label"><%= t("posts.show.type") %></span>
              <span class="ps-room__detail-value"><%= option_icon(@post.post_type, size: 15) %><%= @post.post_type %></span>
            </div>
          </div>

          <div class="ps-room__detail">
            <span class="ps-room__detail-icon"><i class="fa-regular fa-calendar"></i></span>
            <div class="ps-room__detail-body">
              <span class="ps-room__detail-label"><%= t("posts.show.created") %></span>
              <span class="ps-room__detail-value"><%= @post.created_at.strftime("%b %d, %Y") %></span>
            </div>
          </div>
        </div>
      </div>

      <div class="ps-room__card ps-room__card--fill">
        <div class="ps-room__card-head">
          <h2 class="ps-room__card-title"><i class="fa-solid fa-user-group"></i><%= t("posts.show.participants") %></h2>
          <span class="ps-room__pill"><%= render "posts/slots", post: @post %></span>
        </div>

        <div class="ps-room__participants" id="chat_users">
          <% if @chat.users.any? %>
            <% @chat.users.each do |user| %>
              <%= render "posts/chat_user", user: user, post: @post %>
            <% end %>
          <% else %>
            <p class="ps-room__muted"><%= t("posts.show.no_participants") %></p>
          <% end %>
        </div>
      </div>
    </div>

    <%# Right column — vocal + chat %>
    <div class="ps-room__col">
      <div class="ps-room__card ps-room__chat" id="chat_container">
        <div class="ps-room__card-head ps-room__chat-head">
          <h2 class="ps-room__card-title"><i class="fa-solid fa-comment-dots"></i><%= t("posts.show.chat") %></h2>
        </div>
        <p class="ps-room__card-sub"><%= t("posts.show.chat_subtitle") %></p>

        <% if @post.kicked?(current_user) %>
          <%= render "posts/kicked_out" %>
        <% elsif @is_member && @chat %>
          <%= render "posts/voice", post: @post %>

          <div class="ps-room__messages-wrap">
            <div class="ps-room__messages" id="messages" data-controller="scroll" data-scroll-target="messages">
              <% if @chat.messages.any? %>
                <% @chat.messages.each do |message| %>
                  <%= render "messages/message", message: message %>
                <% end %>
              <% else %>
                <div class="ps-room__empty">
                  <span class="ps-room__empty-icon"><i class="fa-regular fa-comments"></i></span>
                  <span class="ps-room__empty-title"><%= t("posts.show.no_messages") %></span>
                  <span class="ps-room__empty-sub"><%= t("posts.show.no_messages_sub") %></span>
                </div>
              <% end %>
            </div>
          </div>

          <div class="ps-room__form" id="form_container">
            <%= render "posts/chat_form", chat: @chat, message: @message %>
          </div>
        <% else %>
          <div class="ps-room__empty">
            <span class="ps-room__empty-icon"><i class="fa-solid fa-lock"></i></span>
            <span class="ps-room__empty-sub">
              <% if @post.full? %>
                <%= t("posts.show.full_chat") %>
              <% else %>
                <%= t("posts.show.join_to_chat") %>
              <% end %>
            </span>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</div>
