
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
  <h1>Find Teammates 🎮</h1>
  <% if policy(Post).new? %>
    <%= link_to "Create Post", new_post_path, class: "btn" %>
  <% end %>
</div>

<%= form_with url: posts_path, method: :get,
              data: { controller: "form", action: "change->form#submit" } do |f| %>
  <div style="display: flex; gap: 15px; align-items: flex-end;">

    <div style="margin-bottom: 1rem;">
      <%= f.label :game_id, "Choose your game", style: "display: block; margin-bottom: 0.5rem; font-weight: bold;" %>

      <input
        type="text"
        id="filter-game-search"
        placeholder="Search a game..."
        autocomplete="off"
        style="width:100%; padding:0.5rem; border: 1px solid #e0e0e0; border-radius: 4px;"
      >

      <%= f.hidden_field :game_id, id: "filter-game-id" %>

      <div id="filter-game-results"></div>
    </div>

    <div style="margin-bottom: 1rem;">
      <%= f.label :platform, "Platform", style: "display: block; margin-bottom: 0.5rem; font-weight: bold;" %>
      <%= f.select :platform, Post::PLATFORMS, { include_blank: "All", selected: params[:platform] }, style: "width: 100%; padding: 0.5rem; border: 1px solid #e0e0e0; border-radius: 4px;" %>
    </div>

    <div style="margin-bottom: 1rem;">
      <%= f.label :post_type, "Type", style: "display: block; margin-bottom: 0.5rem; font-weight: bold;" %>
      <%= f.select :post_type, Post::TYPES, { include_blank: "All", selected: params[:post_type] }, style: "width: 100%; padding: 0.5rem; border: 1px solid #e0e0e0; border-radius: 4px;" %>
    </div>

    <div style="margin-bottom: 1rem;">
      <%= f.label :language, "Language", style: "display: block; margin-bottom: 0.5rem; font-weight: bold;" %>
      <%= f.select :language, Post::LANGUAGES, { include_blank: "All", selected: params[:language] }, style: "width: 100%; padding: 0.5rem; border: 1px solid #e0e0e0; border-radius: 4px;" %>
    </div>

    <div style="margin-bottom: 1.5rem;">
      <%= link_to "Reset", posts_path if params.values_at(:platform, :game, :post_type, :language).any?(&:present?) %>
    </div>

  </div>
<% end %>

<%= turbo_stream_from "posts" %>
<%= render "posts/list", posts: @posts, current_user: current_user %>
