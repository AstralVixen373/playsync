<% content_for :page_title do %>
  <h1>Announcements</h1>
  <p>Find players to share your session</p>
<% end %>

<%= form_with url: posts_path, method: :get,
              data: { controller: "form", action: "change->form#submit" } do |f| %>
  <%= hidden_field_tag :committed, "1" %>

  <div class="ps-filter-bar">

    <div class="ps-filter-game-wrapper">
      <input type="text" id="filter-game-search"
             placeholder="🎮 Games"
             autocomplete="off"
             class="ps-filter-pill-input">
      <div id="filter-game-results"></div>
    </div>

    <%= render "shared/multiselect", name: "platforms[]", options: Post::PLATFORMS,  selected: @selected_platforms,  placeholder: "🖥️ All Platforms" %>
    <%= render "shared/multiselect", name: "post_types[]", options: Post::TYPES,     selected: @selected_post_types, placeholder: "👥 All Types" %>

    <%= select_tag :language, options_for_select(Post::LANGUAGES, @selected_language),
                  include_blank: "🌐 Language", class: "ps-filter-select" %>

    <%= link_to "Reset", posts_path, class: "ps-filter-reset" %>

  </div>

  <%# Game chips appear below the filter bar, not inside it %>
  <div id="filter-game-chips" data-field="game_ids[]" class="ps-game-chips" style="margin-bottom: 1rem;">
    <% @selected_games.each do |game| %>
      <span class="ps-game-chip">
        <%= hidden_field_tag "game_ids[]", game.id %>
        <%= game.name %>
        <button type="button" class="game-chip-remove">×</button>
      </span>
    <% end %>
  </div>

<% end %>

<%= turbo_stream_from "posts" %>
<%= render "posts/list", posts: @posts, current_user: current_user %>
