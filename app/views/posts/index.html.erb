<% content_for :page_title do %>
  <h1><%= t("posts.index.title") %></h1>
  <p>Find players to share your session</p>
<% end %>

<div class="ps-find" data-controller="modal">

  <%# ── Create zone: "I want to create an announcement" ──────────────────── %>
  <%# The CTA opens the creation form as a modal over the (blurred) board. The
  <%# href stays a real link so it still works without JS (lands on /posts/new). %>
  <section class="ps-find__create">
    <span class="ps-find__label"><i class="fa-solid fa-bolt"></i> Got something to play?</span>
    <%= link_to new_post_path, class: "ps-topbar__cta", data: { action: "modal#open" } do %>
      <i class="fa-solid fa-bolt"></i> Create announcement
    <% end %>
  </section>

  <%# ── Search zone: "I'm looking for an announcement" ───────────────────── %>
  <section class="ps-find__search">
    <span class="ps-find__label"><i class="fa-solid fa-magnifying-glass"></i> Find an announcement</span>

    <%= form_with url: posts_path, method: :get,
                  data: { controller: "form", action: "change->form#submit" } do |f| %>
      <%= hidden_field_tag :committed, "1" %>

      <div class="ps-filter-bar">

        <div class="ps-filter-game-wrapper">
          <input type="text" id="filter-game-search"
                 placeholder="🎮 Games"
                 autocomplete="off"
                 class="ps-filter-pill-input">
          <div id="filter-game-results"></div>
        </div>

        <%= render "shared/multiselect", name: "platforms[]", options: Post::PLATFORMS,  selected: @selected_platforms,  placeholder: "🖥️ All Platforms" %>
        <%= render "shared/multiselect", name: "post_types[]", options: Post::TYPES,     selected: @selected_post_types, placeholder: "👥 All Types" %>

        <%= render "shared/multiselect", name: "language", options: Post::LANGUAGES, selected: @selected_language, placeholder: "🌐 Language", single: true %>

        <%= link_to "Reset", posts_path, class: "ps-filter-reset" %>

      </div>

      <%# Game chips appear below the filter bar, not inside it %>
      <div id="filter-game-chips" data-field="game_ids[]" class="ps-game-chips" style="margin-bottom: 0;">
        <% @selected_games.each do |game| %>
          <span class="ps-game-chip">
            <%= hidden_field_tag "game_ids[]", game.id %>
            <%= game.name %>
            <button type="button" class="game-chip-remove">×</button>
          </span>
        <% end %>
      </div>

    <% end %>
  </section>

  <%# ── Create-announcement modal ────────────────────────────────────────── %>
  <%# Overlay blurs the board behind it; the form is the same partial used by
  <%# the standalone /posts/new page so behaviour stays identical. %>
  <div class="ps-modal" data-modal-target="overlay" data-action="click->modal#backdrop keydown.esc@window->modal#close" hidden>
    <div class="ps-modal__card" role="dialog" aria-modal="true" aria-labelledby="ps-modal-title">
      <header class="ps-modal__header">
        <div>
          <span class="ps-find__label"><i class="fa-solid fa-bolt"></i> Got something to play?</span>
          <h2 class="ps-modal__title" id="ps-modal-title"><%= t("posts.new.title") %></h2>
        </div>
        <button type="button" class="ps-modal__close" data-action="modal#close" aria-label="Close">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </header>

      <div class="ps-modal__body">
        <%= render "form", post: @post, modal: true %>
      </div>
    </div>
  </div>

</div>

<%= turbo_stream_from "posts" %>
<%= render "posts/list", posts: @posts, current_user: current_user %>
