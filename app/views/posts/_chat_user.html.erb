<%# One participant row. The kick button keeps its exact route, method and the
    .kick_button / .kick_button_<id> classes the page's <style> block toggles. %>
<div class="ps-room__participant" id="<%= dom_id(user) %>">
  <%= render "shared/avatar", user: user, size: 40 %>
  <span class="ps-room__participant-name"><%= user.username.presence || user.email %></span>
  <%= button_to t("posts.show.kick"), kick_post_path(post, user_id: user.id),
        method: :delete,
        data: { turbo_confirm: t("posts.show.kick_confirm") },
        class: "ps-room__kick kick_button_#{user.id} kick_button" %>
</div>
